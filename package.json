{
  "name": "redmine-time-tracking",
  "description": "Start-stop timer for Redmine",
  "version": "2.0.0-beta.1",
  "author": {
    "name": "CrawlerCode",
    "email": "crawlercode@outlook.de"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/CrawlerCode/redmine-time-tracking"
  },
  "type": "module",
  "scripts": {
    "postinstall": "wxt prepare",
    "dev:chrome": "wxt -b chrome",
    "dev:firefox": "wxt -b firefox --mv2",
    "build:chrome": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip:chrome": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "lint": "eslint --fix src tests fixtures",
    "format": "prettier --write src tests public fixtures",
    "compile": "tsc --noEmit",
    "test": "playwright test",
    "lang:verify": "formatjs verify --source-locale en --missing-keys src/lang/*.json",
    "release": "semantic-release"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@tanstack/query-async-storage-persister": "^5.90.22",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "@tanstack/react-router": "^1.157.16",
    "axios": "^1.13.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.12",
    "date-fns": "^4.1.0",
    "deepmerge": "^4.3.1",
    "lucide-react": "^0.563.0",
    "qs": "^6.14.1",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.4",
    "react-intl": "^8.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@formatjs/cli": "^6.12.0",
    "@playwright/test": "^1.58.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/eslint-plugin-query": "^5.91.3",
    "@tanstack/eslint-plugin-router": "^1.155.0",
    "@tanstack/router-plugin": "^1.157.16",
    "@types/chrome": "^0.1.36",
    "@types/node": "^24.10.9",
    "@types/qs": "^6.14.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "globals": "^17.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "semantic-release": "^25.0.2",
    "shadcn": "^3.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "wxt": "^0.20.13"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ],
    "patchedDependencies": {
      "@base-ui/react@1.1.0": "patches/@base-ui__react@1.1.0.patch"
    }
  }
}
