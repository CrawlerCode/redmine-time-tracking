{
  "name": "redmine-time-tracking",
  "description": "Redmine Time Tracking",
  "version": "1.21.2",
  "author": {
    "name": "CrawlerCode",
    "email": "crawlercode@outlook.de"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/CrawlerCode/redmine-time-tracking"
  },
  "type": "module",
  "scripts": {
    "dev:chrome": "tsc && cross-env PLATFORM=chrome vite build --watch --mode development",
    "dev:firefox": "tsc && cross-env PLATFORM=firefox vite build --watch --mode development",
    "build": "pnpm run build:chrome && pnpm run build:firefox",
    "build:chrome": "tsc && cross-env PLATFORM=chrome vite build",
    "build:firefox": "tsc && cross-env PLATFORM=firefox vite build",
    "release": "gh release create v%npm_package_version% --notes-file release_notes.md --generate-notes",
    "lint": "eslint --fix src tests fixtures",
    "format": "prettier --write src tests public fixtures",
    "test": "playwright test",
    "lang:verify": "formatjs verify --source-locale en --missing-keys src/lang/*.json"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/query-async-storage-persister": "^5.66.0",
    "@tanstack/react-form": "^1.12.0",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-query-devtools": "^5.66.0",
    "@tanstack/react-query-persist-client": "^5.66.0",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-flag-icons": "^1.5.14",
    "date-fns": "^3.6.0",
    "deepmerge": "^4.3.1",
    "lucide-react": "^0.546.0",
    "next-themes": "^0.4.6",
    "qs": "^6.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.0.0",
    "react-intl": "^7.1.11",
    "react-router-dom": "^7.1.5",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.46"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@formatjs/cli": "^6.7.1",
    "@playwright/test": "^1.50.1",
    "@types/chrome": "^0.0.301",
    "@types/node": "^22.13.1",
    "@types/qs": "^6.9.18",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vite": "^6.1.0",
    "vite-plugin-static-copy": "^2.2.0",
    "vite-plugin-zip-pack": "^1.2.4"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  }
}
