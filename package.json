{
  "name": "redmine-time-tracking",
  "description": "Redmine Time Tracking",
  "version": "2.0.0",
  "author": {
    "name": "CrawlerCode",
    "email": "crawlercode@outlook.de"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/CrawlerCode/redmine-time-tracking"
  },
  "type": "module",
  "scripts": {
    "postinstall": "wxt prepare",
    "dev:chrome": "wxt -b chrome",
    "dev:firefox": "wxt -b firefox --mv2",
    "build:chrome": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip:chrome": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "release": "gh release create v%npm_package_version% --notes-file release_notes.md --generate-notes",
    "lint": "eslint --fix src tests fixtures",
    "format": "prettier --write src tests public fixtures",
    "compile": "tsc --noEmit",
    "test": "playwright test",
    "lang:verify": "formatjs verify --source-locale en --missing-keys src/lang/*.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@tanstack/query-async-storage-persister": "^5.66.0",
    "@tanstack/react-form": "^1.12.0",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-query-devtools": "^5.66.0",
    "@tanstack/react-query-persist-client": "^5.66.0",
    "@tanstack/react-router": "^1.141.2",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.5.14",
    "date-fns": "^3.6.0",
    "deepmerge": "^4.3.1",
    "lucide-react": "^0.546.0",
    "next-themes": "^0.4.6",
    "qs": "^6.14.0",
    "react": "^19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.3",
    "react-intl": "^7.1.11",
    "shadcn": "^3.6.3",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@formatjs/cli": "^6.7.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@tanstack/eslint-plugin-router": "^1.141.0",
    "@tanstack/router-plugin": "^1.141.2",
    "@types/chrome": "^0.0.301",
    "@types/node": "^22.13.1",
    "@types/qs": "^6.9.18",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vite": "^7.3.0",
    "wxt": "^0.20.12"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ],
    "patchedDependencies": {
      "@base-ui/react@1.1.0": "patches/@base-ui__react@1.1.0.patch"
    }
  }
}
